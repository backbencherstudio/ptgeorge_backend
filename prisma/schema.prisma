generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

enum UserType {
  SUPER_ADMIN
  ADMIN
  CHURCH_ADMIN
  USER
  PRO_USER
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

// ==========================================
// Account 
// ==========================================

model Account {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  user_id String
  user    User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  type                String?
  provider            String?
  provider_account_id String?
  refresh_token       String?
  access_token        String?
  expires_at          DateTime?
  token_type          String?
  scope               String?
  id_token            String?
  session_state       String?

  @@unique([provider, provider_account_id])
  @@map("accounts")
}

// ==========================================
//  USER MODEL
// ==========================================

model User {
  id         String      @id @default(cuid())
  created_at DateTime    @default(now())
  updated_at DateTime    @default(now())
  deleted_at DateTime?
  status     UserStatus? @default(PENDING)

  first_name   String @db.VarChar(255)
  last_name    String @db.VarChar(255)
  phone_number String @db.VarChar(255)
  church_name  String @db.VarChar(255)
  language     String @db.VarChar(100)

  email    String    @unique
  password String    @db.VarChar(255)
  type     UserType? @default(USER)

  // professional setup
  company_name    String? @db.VarChar(255)
  business_email  String? @db.VarChar(255)
  business_phone  String? @db.VarChar(255)
  service         String? @db.VarChar(255)
  category        String? @db.VarChar(255)
  profession      String? @db.VarChar(255)
  website         String? @db.VarChar(255)
  whatsapp_number String? @db.VarChar(255)
  available_time  String? @db.VarChar(255)
  address_line1   String? @db.VarChar(255)
  address_line2   String? @db.VarChar(255)
  state           String? @db.VarChar(255)
  country         String? @db.VarChar(255)
  zip_code        String? @db.VarChar(255)

  business_portfolio String? @db.Text
  description        String? @db.Text
  other_locations    String? @db.Text

  // fcm token for push notifications 
  fcm_token String?
  google_id String? @unique
  apple_id  String? @unique

  // other info
  avatar   String?
  about_me String?
  address  String?

  name     String? @db.VarChar(255)
  location String? @db.VarChar(255)

  // billing info  
  billing_id        String?
  // stripe connect account 
  stripe_connect_id String?
  //user balance
  balance           Decimal?  @default(0.0) @db.Decimal(10, 2)
  // email verification
  email_verified_at DateTime?

  // portfolio images 
  portfolio_images String[] @db.Text

  // Skills and expertise
  skills skills[] @relation("UserSkills")

  //----------------------------------------
  bio           String?   @db.Text
  domain        String?   @unique
  username      String?   @unique
  city          String?
  gender        String?
  date_of_birth DateTime? @db.Date
  approved_at   DateTime?
  availability  String?

  is_two_factor_enabled Int?      @default(0)
  two_factor_secret     String?
  accounts              Account[]

  // -----------------(relation)-------------------

  // --- Conversation & Messaging ---
  participants Participant[] @relation("participantUser")
  sentMessages Message[]     @relation("messageSender")

  // --- Notifications ---
  receivedNotifications Notification[] @relation("notificationReceiver")
  sentNotifications     Notification[] @relation("notificationSender")

  // --- Other Relation --- 
  ucodes                   Ucode[]
  roles_assigned_to_me     RoleUser[]                @relation("UserRoles")
  roles_i_assigned         RoleUser[]                @relation("RoleAssignment")
  userNotificationSettings UserNotificationSetting[]

  // church
  churchUser         Church[]          @relation("ChurchToUser")
  church_memberships ChurchMember[]    @relation("UserToMemberships")

  // ads manager
  created_ads Ad[]      @relation("UserCreatedAds")
  ad_views    AdView[]  @relation("UserAdViews")
  ad_clicks   AdClick[] @relation("UserAdClicks")

  // ann
  created_announcements Announcement[] @relation("UserCreatedAnnouncements")

  // Follow relationships
  following UserFollow[] @relation("Following")
  followers UserFollow[] @relation("Followers")

  // Reviews received (as a PRO_USER)
  received_reviews Review[] @relation("ReviewedUser")

  // Reviews written (as a reviewer)
  written_reviews Review[] @relation("ReviewAuthor")

  // Review helpful votes
  review_helpful_votes ReviewHelpfulVote[]

  // Review replies
  review_replies ReviewReply[]

  @@map("users")
}

// ==========================================
// FOLLOW SYSTEM
// ==========================================

model UserFollow {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  follower_id String
  follower    User @relation("Following", fields: [follower_id], references: [id], onDelete: Cascade)

  following_id String
  following    User @relation("Followers", fields: [following_id], references: [id], onDelete: Cascade)

  status FollowStatus @default(ACTIVE)

  @@unique([follower_id, following_id])
  @@index([follower_id])
  @@index([following_id])
  @@index([created_at])
  @@map("user_follows")
}

enum FollowStatus {
  ACTIVE
  BLOCKED
  REQUESTED
}

// ==========================================
// REVIEW SYSTEM
// ==========================================

model Review {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  deleted_at DateTime?

  rating     Int     @db.SmallInt
  comment    String? @db.Text
  images     String[] @db.Text

  reviewer_id String
  reviewer    User @relation("ReviewAuthor", fields: [reviewer_id], references: [id], onDelete: Cascade)

  reviewed_user_id String
  reviewed_user    User @relation("ReviewedUser", fields: [reviewed_user_id], references: [id], onDelete: Cascade)

  helpful_votes ReviewHelpfulVote[]
  replies       ReviewReply[]

  church_id String
  church    Church @relation("ChurchReviews", fields: [church_id], references: [id], onDelete: Cascade)

  status ReviewStatus @default(PUBLISHED)

  @@unique([reviewer_id, reviewed_user_id])
  @@index([reviewed_user_id])
  @@index([reviewer_id])
  @@index([rating])
  @@index([created_at])
  @@index([church_id])
  @@map("reviews")
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
  FLAGGED
}

model ReviewHelpfulVote {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())

  review_id String
  review    Review @relation(fields: [review_id], references: [id], onDelete: Cascade)

  user_id String
  user    User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  is_helpful Boolean @default(true)

  @@unique([review_id, user_id])
  @@index([review_id])
  @@index([user_id])
  @@map("review_helpful_votes")
}

model ReviewReply {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  deleted_at DateTime?

  comment String  @db.Text
  images  String[] @db.Text

  review_id String
  review    Review @relation(fields: [review_id], references: [id], onDelete: Cascade)

  reply_by_id String
  reply_by    User @relation(fields: [reply_by_id], references: [id], onDelete: Cascade)

  @@index([review_id])
  @@index([reply_by_id])
  @@index([created_at])
  @@map("review_replies")
}

// ==========================================
// REST OF THE SCHEMA
// ==========================================

model Ucode {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now())
  status     Int?     @default(1) @db.SmallInt

  user_id String?
  user    User?   @relation(fields: [user_id], references: [id])

  token       String?
  email       String?
  expired_at  DateTime?
  verified_at DateTime?

  @@map("ucodes")
}
  
model skills {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt
  deleted_at DateTime?

  skill_name String

  user_id String
  user    User @relation("UserSkills", fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, skill_name])
  @@map("skills")
}

/**
 * ---------------------------------------------------------------------
 * Church Schema with Posts, Comments, Reacts
 * ---------------------------------------------------------------------
 */

enum ChurchAuthType {
  SYSTEM_ADMIN
  EDITOR
  HELPER
  CHURCH_ADMIN
}

enum ChurchStatus {
  PENDING
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ChurchMemberStatus {
  PENDING
  ACTIVE
  INACTIVE
  REMOVED
}

enum ReactType {
  LIKE
  LOVE
}

model Church {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?

  church_name      String @db.VarChar(255)
  church_city      String @db.VarChar(255)
  church_email     String @unique
  church_domain    String @unique
  church_adminname String @db.VarChar(255)
  
  church_address   String? @db.Text
  church_description String? @db.Text
  church_phone     String? @db.VarChar(50)

  google_id String? @unique
  apple_id  String? @unique

  church_members Int? @default(0)

  status    ChurchStatus   @default(PENDING)
  auth_type ChurchAuthType @default(CHURCH_ADMIN)

  user_id String?
  user    User?   @relation("ChurchToUser", fields: [user_id], references: [id], onDelete: Cascade)

  roleUsers RoleUser[]
  members   ChurchMember[] @relation("ChurchToMembers")
  posts     ChurchPost[]   @relation("ChurchToPosts")
  reviews   Review[]       @relation("ChurchReviews")

  @@map("churches")
}

model ChurchMember {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now()) @updatedAt
  deleted_at DateTime?

  church_id String
  church    Church @relation("ChurchToMembers", fields: [church_id], references: [id], onDelete: Cascade)

  user_id String
  user    User   @relation("UserToMemberships", fields: [user_id], references: [id], onDelete: Cascade)

  church_role String?            @db.VarChar(100)
  status      ChurchMemberStatus @default(ACTIVE)
  joined_at   DateTime           @default(now())

  approved_by String?
  approved_at DateTime?
  notes       String?   @db.Text

  posts   ChurchPost[]        @relation("MemberToPosts")
  comments ChurchComment[]    @relation("MemberToComments")
  reacts   ChurchPostReact[]  @relation("MemberToReacts")
  replies  ChurchCommentReply[] @relation("MemberToCommentReplies")

  @@unique([church_id, user_id])
  @@index([church_id])
  @@index([user_id])
  @@index([status])
  @@map("church_members")
}

model ChurchPost {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  deleted_at DateTime?

  images    String[]  @db.Text
  content   String?   @db.Text

  church_id String
  church    Church @relation("ChurchToPosts", fields: [church_id], references: [id], onDelete: Cascade)

  church_member_id String
  church_member    ChurchMember @relation("MemberToPosts", fields: [church_member_id], references: [id], onDelete: Cascade)

  comments ChurchComment[]    @relation("PostToComments")
  reacts   ChurchPostReact[]  @relation("PostToReacts")

  @@index([church_id])
  @@index([church_member_id])
  @@index([created_at])
  @@map("church_posts")
}

model ChurchComment {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  deleted_at DateTime?

  content String @db.Text
  image   String?

  post_id String
  post    ChurchPost @relation("PostToComments", fields: [post_id], references: [id], onDelete: Cascade)

  church_member_id String
  church_member    ChurchMember @relation("MemberToComments", fields: [church_member_id], references: [id], onDelete: Cascade)

  replies ChurchCommentReply[] @relation("CommentToReplies")

  @@index([post_id])
  @@index([church_member_id])
  @@index([created_at])
  @@map("church_comments")
}

model ChurchCommentReply {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  deleted_at DateTime?

  content String @db.Text
  image   String?

  comment_id String
  comment    ChurchComment @relation("CommentToReplies", fields: [comment_id], references: [id], onDelete: Cascade)

  church_member_id String
  church_member    ChurchMember @relation("MemberToCommentReplies", fields: [church_member_id], references: [id], onDelete: Cascade)

  @@index([comment_id])
  @@index([church_member_id])
  @@index([created_at])
  @@map("church_comment_replies")
}

model ChurchPostReact {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  react_type ReactType @default(LOVE)

  post_id String
  post    ChurchPost @relation("PostToReacts", fields: [post_id], references: [id], onDelete: Cascade)

  church_member_id String
  church_member    ChurchMember @relation("MemberToReacts", fields: [church_member_id], references: [id], onDelete: Cascade)

  @@unique([post_id, church_member_id])
  @@index([post_id])
  @@index([church_member_id])
  @@map("church_post_reacts")
}

/**
 * ---------------------------------------------------------------------
 * Chatting Schema
 * ---------------------------------------------------------------------
 */

model Conversation {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  messages     Message[]
  participants Participant[]
}

model Participant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("participantUser", fields: [userId], references: [id], onDelete: Cascade)

  role     String?  @default("participant")
  joinedAt DateTime @default(now())

  lastReadAt DateTime?

  @@unique([conversationId, userId])
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
  PENDING
}

model Message {
  id        String   @id @default(cuid())
  text      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status MessageStatus @default(PENDING)

  senderId String
  sender   User   @relation("messageSender", fields: [senderId], references: [id], onDelete: Cascade)

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  attachments String[] @db.Text
}

/**
 * ---------------------------------------------------------------------
 * Notification Schema
 * ---------------------------------------------------------------------
 */

//  notification event
model NotificationEvent {
  id         String   @id @default(uuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  status Int? @default(1) @db.SmallInt

  type          String?
  text          String?
  notifications Notification[]
}

model Notification {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt

  read_at DateTime?
  status  Int?      @default(1) @db.SmallInt

  sender_id String?
  sender    User?   @relation("notificationSender", fields: [sender_id], references: [id])

  receiver_id String?
  receiver    User?   @relation("notificationReceiver", fields: [receiver_id], references: [id])

  notification_event_id String?
  notification_event    NotificationEvent? @relation(fields: [notification_event_id], references: [id])

  entity_id String?
}


//=====================(Notification Settings)==========================

enum NotificationSettingType {
  NEW_REQUEST_ALERT
  APPROVAL_CONFIRMATION
  ROLE_ASSIGNMENT_ALERT
  NEW_REVIEW_ALERT
  NEW_FOLLOW_ALERT
}

model UserNotificationSetting {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  type       NotificationSettingType
  is_enabled Boolean                 @default(true)

  @@unique([user_id, type])
  @@index([user_id])
  @@map("user_notification_settings")
}

/**
 * ---------------------------------------------------------------------
 * ADS MANAGER SCHEMA
 * ---------------------------------------------------------------------
 */

enum AdStatus {
  ACTIVE
  PAUSED
  HIDDEN
}

enum AdPlacement {
  HOME_BANNER
  SIDEBAR
  IN_ARTICLE
  POPUP
  FULLSCREEN
  CHURCH_FEED
}

model Ad {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  title       String @db.VarChar(255)
  description String @db.Text
  link        String @db.VarChar(500)
  thumbnail   String @db.VarChar(500)

  status    AdStatus    @default(ACTIVE)
  placement AdPlacement @default(HOME_BANNER)

  country String?
  city    String?

  start_date DateTime
  end_date   DateTime

  total_views  Int @default(0)
  total_clicks Int @default(0)

  created_by_id String
  created_by    User   @relation("UserCreatedAds", fields: [created_by_id], references: [id])

  ad_views   AdView[]
  ad_clicks  AdClick[]
  ad_metrics AdMetrics[]

  @@index([status])
  @@index([placement])
  @@index([start_date, end_date])
  @@map("ads")
}

model AdView {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())

  ad_id String
  ad    Ad     @relation(fields: [ad_id], references: [id], onDelete: Cascade)

  user_id String?
  user    User?   @relation("UserAdViews", fields: [user_id], references: [id])

  ip_address String?
  user_agent String?

  @@index([ad_id])
  @@index([created_at])
  @@map("ad_views")
}

model AdClick {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())

  ad_id String
  ad    Ad     @relation(fields: [ad_id], references: [id], onDelete: Cascade)

  user_id String?
  user    User?   @relation("UserAdClicks", fields: [user_id], references: [id])

  ip_address String?
  user_agent String?

  @@index([ad_id])
  @@index([created_at])
  @@map("ad_clicks")
}

model AdMetrics {
  id         String   @id @default(cuid())
  date       DateTime @default(now())
  updated_at DateTime @default(now())

  ad_id String
  ad    Ad     @relation(fields: [ad_id], references: [id], onDelete: Cascade)

  views  Int @default(0)
  clicks Int @default(0)

  @@unique([ad_id, date])
  @@index([ad_id])
  @@index([date])
  @@map("ad_metrics")
}

/**
 * ---------------------------------------------------------------------
 * ANNOUNCEMENT SCHEMA
 * ---------------------------------------------------------------------
 */

enum AnnouncementAudience {
  ALL_USERS
  CHURCH_ADMINS_ONLY
  SUPER_ADMINS_ONLY
  SPECIFIC_CHURCHES
}

enum AnnouncementStatus {
  PUBLISHED
  UNPUBLISHED
}

model Announcement {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deleted_at DateTime?

  title   String @db.VarChar(255)
  message String @db.Text

  status   AnnouncementStatus   @default(UNPUBLISHED)
  audience AnnouncementAudience @default(ALL_USERS)

  start_date DateTime
  end_date   DateTime

  target_church_ids String[]

  created_by_id String
  created_by    User   @relation("UserCreatedAnnouncements", fields: [created_by_id], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([audience])
  @@index([start_date, end_date])
  @@index([created_at])
  @@index([created_by_id])
  @@map("announcements")
}

/**
 * ---------------------------------------------------------------------
 * Role and Permission Schema
 * ---------------------------------------------------------------------
 */

model Role {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status Int?    @default(1) @db.SmallInt
  title  String?
  name   String?

  description String?
  color       String?

  permission_roles PermissionRole[]
  role_users       RoleUser[]
  permissions      Permission[]         @relation("PermissionToRole")
  from_role_rules  RoleAssignmentRule[] @relation("FromRole")
  to_role_rules    RoleAssignmentRule[] @relation("ToRole")

  @@map("roles")
}

model Permission {
  id         String    @id @default(cuid())
  created_at DateTime  @default(now())
  updated_at DateTime  @default(now())
  deleted_at DateTime?

  status      PermissionStatus  @default(ACTIVE)
  title       String?
  name        String?           @unique
  action      PermissionAction?
  category    String?
  description String?           @db.Text
  conditions  String?
  fields      String?

  permission_roles PermissionRole[]
  roles            Role[]           @relation("PermissionToRole")

  @@map("permissions")
}

model PermissionRole {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  permission_id String
  permission    Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  role_id String
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([permission_id, role_id])
  @@map("permission_roles")
}

model RoleUser {
  created_at DateTime @default(now())
  updated_at DateTime @default(now())

  role_id String
  role    Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)

  user_id String
  user    User   @relation("UserRoles", fields: [user_id], references: [id], onDelete: Cascade)

  assigned_by_id String?
  assigned_by    User?   @relation("RoleAssignment", fields: [assigned_by_id], references: [id])

  churchId String?
  church   Church? @relation(fields: [churchId], references: [id])

  @@id([role_id, user_id])
  @@map("role_users")
}

model RoleAssignmentRule {
  id           String   @id @default(cuid())
  created_at   DateTime @default(now())
  updated_at   DateTime @default(now())
  from_role_id String
  from_role    Role     @relation("FromRole", fields: [from_role_id], references: [id])
  to_role_id   String
  to_role      Role     @relation("ToRole", fields: [to_role_id], references: [id])

  @@unique([from_role_id, to_role_id])
  @@map("role_assignment_rules")
}

enum PermissionStatus {
  ACTIVE
  INACTIVE
}

enum PermissionAction {
  manage
  read
  create
  update
  delete
  assign
}

// ==========================================
// SIMPLE AUDIT LOGS SCHEMA
// ==========================================

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  VIEW
  ASSIGN
  REVOKE
  APPROVE
  REJECT
  SUSPEND
  ACTIVATE
  EXPORT
  LOGIN
  LOGOUT
  CHANGE_STATUS
  MANAGE_PERMISSIONS
  MANAGE_ROLES
  MANAGE_CHURCH
  MANAGE_USERS
  DELETED_PERMISSION
  ASSIGNED_ROLE
  REVOKED_ROLE
  FOLLOW
  UNFOLLOW
  REVIEW_ADDED
  REVIEW_UPDATED
  REVIEW_DELETED
  REVIEW_HELPFUL_VOTE
}

model AuditLog {
  id         String   @id @default(cuid())
  created_at DateTime @default(now())
  
  actor    String
  action   String
  target   String
  church   String?
  
  actor_id   String?
  actor_type String?
  church_id  String?
  
  @@index([created_at(sort: Desc)])
  @@index([actor])
  @@index([action])
  @@index([church_id])
  @@index([church])
  @@map("audit_logs")
}